{
  "name": "cute-claude-hooks",
  "version": "1.3.0",
  "description": "关镇江原创增强版：Claude Code 中文提示、界面汉化与监控状态栏",
  "main": "index.js",
  "scripts": {
    "postinstall": "node -e \"console.log('\\n🌸 关镇江原创增强版已安装到全局环境! 🌸\\n\\n下一步请运行:\\n\\n  cute-claude-hooks-install\\n\\n当前仓库支持公开 Git 安装。\\n')\"",
    "uninstall": "node -e \"console.log('\\n🌸 卸载 cute-claude-hooks... 🌸\\n请手动删除 ~/.claude/hooks/tool-tips-post.sh、~/.claude/localize/ 和 ~/.claude/monitor/ 目录\\n')\""
  },
  "bin": {
    "cute-claude-hooks-install": "bin/install.js",
    "cute-claude-hooks-restore": "bin/restore.js",
    "cute-claude-hooks-refresh-assets": "bin/refresh-assets.js"
  },
  "files": [
    "bin/",
    "localize/",
    "monitor/",
    "tool-tips-post.sh",
    "INSTALL_AND_USAGE.html",
    "README.md",
    "LICENSE"
  ],
